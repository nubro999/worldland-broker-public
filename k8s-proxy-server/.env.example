# ================================
# 로컬 개발 환경 설정
# ================================
# 이 파일을 복사하여 .env 로 저장하고 값을 채워주세요

# Google OAuth 설정
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT 설정 (프로덕션에서는 반드시 변경!)
JWT_SECRET=your-jwt-secret-change-in-production

# 서버 설정
PROXY_PORT=8080
DEBUG_MODE=false

# CORS 설정 (개발 환경에서는 * 사용)
ALLOWED_ORIGINS=*

# K8s 설정 (로컬에서 K8s 연동 시에만 필요)
K8S_MASTER_URL=
K8S_TOKEN=

# ================================
# Redis 설정
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# Provider Orchestrator 설정
# ================================
# Orchestrator를 활성화하려면 true로 설정
ENABLE_ORCHESTRATOR=false
# 마스터 노드의 Public IP (Provider Agent가 join할 때 사용)
MASTER_PUBLIC_IP=
# Kubernetes API 서버 포트 (기본: 6443)
MASTER_API_PORT=6443
